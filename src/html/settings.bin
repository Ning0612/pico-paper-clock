<!doctype html><html lang="zh-TW"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Pi Paper Clock / 設定</title><link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' fill='%230a100d'/%3E%3Crect x='2' y='2' width='28' height='28' fill='none' stroke='%23a8d2c4' stroke-width='2'/%3E%3Ctext x='16' y='21' font-family='Consolas,monospace' font-size='12' font-weight='700' fill='%23a8d2c4' text-anchor='middle'%3EPC%3C/text%3E%3C/svg%3E"><script>(function(){var k='iot-ui-theme',s=null;try{s=localStorage.getItem(k)}catch(e){}document.documentElement.dataset.theme=(s==='light'||s==='dark')?s:(matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light')})();</script><style>:root{color-scheme:light;--paper:#f1ede2;--surface:#fbf8ef;--surface-2:#e7e3d6;--ink:#17231f;--ink-soft:#263a34;--line:#b9b8aa;--muted:#68736c;--teal:#0b716a;--teal-dark:#07534f;--coral:#cf5a47;--coral-dark:#a94436;--amber:#bd812d;--amber-dark:#98641d;--shadow:rgba(23,35,31,.15);--inset:#fffdf7;--input-border:#7e9188;--chart-grid:#d4d2c5;--unknown:#a9ada3;--placeholder:#9aa39b;--grid-dot:rgba(23,35,31,.045);--danger-surface:#fff6ed;--mint:#a8d2c4;--on-dark:#fbf8ef;--on-light:#17231f;--dark-block-muted:#aab8ae;--nav-border:#71847a;--on-ring:rgba(168,210,196,.18);--off-ring:rgba(207,90,71,.18)}:root[data-theme="dark"]{color-scheme:dark;--paper:#141b18;--surface:#1c2622;--surface-2:#24312c;--ink:#eef1ea;--ink-soft:#0a100d;--line:#3a4a43;--muted:#93a69c;--teal:#1fae9c;--teal-dark:#167d70;--coral:#e2705a;--coral-dark:#b8543f;--amber:#d99a3f;--amber-dark:#a97a2f;--shadow:rgba(0,0,0,.4);--inset:#101512;--input-border:#48584f;--chart-grid:#3a473f;--unknown:#6b756e;--placeholder:#66756c;--grid-dot:rgba(255,255,255,.035);--danger-surface:#241a16}*{box-sizing:border-box}body{margin:0;background-color:var(--paper);background-image:linear-gradient(var(--grid-dot) 1px,transparent 1px),linear-gradient(90deg,var(--grid-dot) 1px,transparent 1px);background-size:20px 20px;color:var(--ink);font-family:Georgia,'Noto Serif TC',serif;min-height:100vh}.topbar{background:var(--ink-soft);border-bottom:5px solid var(--coral);color:var(--on-dark);padding:1rem}.topbar-in{max-width:1040px;margin:auto;display:flex;align-items:center;justify-content:space-between;gap:1rem}.brand{display:flex;align-items:center;gap:.7rem;color:inherit;text-decoration:none}.brand-mark{display:grid;place-items:center;width:2.25rem;height:2.25rem;border:2px solid var(--mint);color:var(--mint);font:700 1rem Consolas,monospace}.brand-copy{font:700 .82rem Consolas,monospace;letter-spacing:.08em}.brand-sub{display:block;margin-top:.22rem;color:var(--dark-block-muted);font:400 .68rem Consolas,monospace;letter-spacing:.02em}.topbar-actions{display:flex;align-items:center;gap:.6rem;flex-wrap:wrap}.nav{display:flex;gap:.4rem;flex-wrap:wrap;justify-content:flex-end}.nav a{border:1px solid var(--nav-border);color:var(--on-dark);padding:.46rem .6rem;text-decoration:none;font:700 .72rem Consolas,monospace}.nav a:hover,.nav a.active{background:var(--mint);border-color:var(--mint);color:var(--on-light)}.theme-toggle{display:flex;border:1px solid var(--nav-border);overflow:hidden}.theme-toggle button{border:0;border-radius:0;padding:.46rem .6rem;background:transparent;color:var(--on-dark);font:700 .68rem Consolas,monospace;letter-spacing:.04em;cursor:pointer}.theme-toggle button+button{border-left:1px solid var(--nav-border)}.theme-toggle button.active{background:var(--mint);color:var(--on-light)}.theme-toggle button:hover:not(.active){background:var(--on-ring)}.wrap{max-width:1040px;margin:auto;padding:1.4rem 1rem 3rem}.kicker{color:var(--teal);font:700 .72rem Consolas,monospace;letter-spacing:.14em;text-transform:uppercase}.intro{display:flex;align-items:flex-end;justify-content:space-between;gap:1.5rem;margin:.4rem 0 1.25rem}.intro h1{font-size:clamp(2rem,6vw,4rem);line-height:.92;letter-spacing:-.06em;margin:.45rem 0 0}.intro p{max-width:30rem;margin:0;color:var(--muted);line-height:1.55}.profile-strip{display:grid;grid-template-columns:minmax(0,1fr) auto auto;gap:.55rem;padding:.8rem;background:var(--ink-soft);box-shadow:5px 5px 0 var(--line);margin-bottom:1rem}.profile-strip label{color:var(--mint);align-self:center;font:700 .72rem Consolas,monospace;letter-spacing:.08em}.profile-strip select{grid-column:1/-1}.card{position:relative;background:var(--surface);border:1px solid var(--ink);padding:1.05rem;margin-bottom:1rem;box-shadow:5px 5px 0 var(--line)}.card:before{content:'';position:absolute;top:0;left:0;width:42px;height:4px;background:var(--teal)}.card h2{display:flex;align-items:baseline;gap:.55rem;margin:0 0 1rem;padding-bottom:.65rem;border-bottom:1px solid var(--line);font-size:1.05rem}.card h2 span{color:var(--coral);font:700 .7rem Consolas,monospace}.danger-card{border-color:var(--coral);background:var(--danger-surface)}.danger-card:before{background:var(--coral)}.danger-card h2{color:var(--coral)}form{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:1rem}.wide{grid-column:1/-1}.field{margin-bottom:.85rem}.field:last-child{margin-bottom:0}label{display:block;margin-bottom:.3rem;color:var(--muted);font:700 .72rem Consolas,monospace;letter-spacing:.03em}input,select,button{font:700 .88rem Consolas,monospace}input,select{width:100%;padding:.64rem .68rem;border:1px solid var(--input-border);border-radius:0;background:var(--inset);color:var(--ink)}input:focus,select:focus{outline:2px solid var(--mint);outline-offset:1px;border-color:var(--teal)}input::placeholder{color:var(--placeholder);font-weight:400}.check{display:flex;align-items:flex-start;gap:.55rem;padding:.55rem 0}.check input{width:auto;margin:.1rem 0 0;accent-color:var(--teal);transform:scale(1.1)}.check label{margin:0;color:var(--ink);line-height:1.35}.hint{margin:.35rem 0 0;color:var(--muted);font:400 .76rem Consolas,monospace}.hint strong{color:var(--teal)}.section-note{margin:-.45rem 0 .9rem;color:var(--muted);font-size:.82rem;line-height:1.45}.field-with-action{display:flex;gap:.5rem;align-items:stretch}.field-with-action select{flex:1}.field-with-action button{flex:none;white-space:nowrap}button{border:1px solid var(--teal-dark);border-radius:0;padding:.7rem .85rem;cursor:pointer;background:var(--teal);color:#fff}button:hover{background:var(--teal-dark)}button.danger{border-color:var(--coral);background:var(--coral)}button.danger:hover{background:var(--coral-dark)}button.warn{border-color:var(--amber);background:var(--amber)}button.warn:hover{background:var(--amber-dark)}button.ghost{background:transparent;border-color:var(--teal);color:var(--teal)}button.ghost:hover{background:var(--teal);color:#fff}button:disabled{opacity:.55;cursor:wait}button:focus-visible,.nav a:focus-visible{outline:2px solid var(--mint);outline-offset:2px}.actions{display:flex;gap:.6rem;flex-wrap:wrap}.actions button{flex:1;min-width:170px}.message{display:none;margin-bottom:1rem;padding:.8rem 1rem;border:1px solid var(--teal);border-left:5px solid var(--teal);background:var(--surface);font:700 .8rem Consolas,monospace}.message.error{border-color:var(--coral);color:var(--coral)}.info{color:var(--muted);font-size:.82rem;line-height:1.5;margin:.85rem 0 0;padding:.65rem .75rem;background:var(--surface-2);border-left:3px solid var(--teal)}.site-footer{background:var(--ink-soft);color:var(--dark-block-muted);margin-top:2rem;padding:1.2rem 1rem}.footer-in{max-width:1040px;margin:auto;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap}.footer-repo{display:flex;align-items:baseline;gap:.5rem;font:700 .74rem Consolas,monospace}.footer-repo .label{color:var(--mint);text-transform:uppercase;letter-spacing:.12em}.footer-repo a{color:var(--on-dark);text-decoration:none;border-bottom:1px solid var(--nav-border)}.footer-repo a:hover{color:var(--mint);border-color:var(--mint)}.footer-meta{color:var(--dark-block-muted);font:400 .7rem Consolas,monospace}.is-hidden{display:none!important}@media(min-width:760px){.metric-grid{grid-template-columns:repeat(6,1fr)}}@media(max-width:720px){.topbar-in,.intro{align-items:flex-start;flex-direction:column}.nav{justify-content:flex-start}.topbar-actions{align-items:flex-start}.profile-strip{grid-template-columns:1fr 1fr}.profile-strip label,.profile-strip select{grid-column:1/-1}.profile-strip button{width:100%}form{grid-template-columns:1fr}.wide{grid-column:auto}.wrap{padding-top:1rem}}@media(max-width:480px){.footer-in{flex-direction:column;align-items:flex-start}}</style><style>button{color:var(--on-dark)}button.ghost:hover{color:var(--on-dark)}</style><style>.topbar .logout{border-color:var(--nav-border);background:transparent;color:var(--on-dark);padding:.46rem .6rem;font-size:.68rem}.topbar .logout:hover{background:var(--mint);color:var(--on-light)}</style></head><body><header class="topbar"><div class="topbar-in"><a class="brand" href="/"><span class="brand-mark">PC</span><span class="brand-copy">PI PAPER CLOCK<span class="brand-sub">LOCAL DEVICE / CONTROL DECK</span></span></a><div class="topbar-actions"><nav class="nav" aria-label="主導覽"><a class="active" href="/">設定</a><a href="/dashboard">在席統計</a><a href="/images">圖片庫</a></nav><div class="theme-toggle" role="group" aria-label="配色主題切換"><button type="button" data-theme-choice="light" aria-pressed="false">LIGHT</button><button type="button" data-theme-choice="dark" aria-pressed="false">DARK</button></div><button type="button" class="logout ghost" id="logout">登出</button></div></div></header><main class="wrap"><div class="intro"><div><div class="kicker">01 / configuration</div><h1>裝置設定</h1></div><p>管理時鐘的網路、顯示內容、感測器與提示音。儲存後裝置會自動重新啟動。</p></div><div class="profile-strip"><label for="profiles">CURRENT PROFILE</label><select id="profiles" aria-label="目前設定檔"></select><button id="newProfile" class="ghost" type="button">新增</button><button id="deleteProfile" class="danger" type="button">刪除</button></div><div class="message" id="message" aria-live="polite"></div><form id="settings"><input type="hidden" name="csrf_token" id="csrf"><input type="hidden" name="original_profile_name" id="originalName"><section class="card"><h2><span>01</span>設定檔與 Wi-Fi</h2><div class="field"><label for="profileName">設定檔名稱</label><input id="profileName" name="profile_name" maxlength="32" required></div><div class="field"><label for="ssid">Wi-Fi SSID</label><div class="field-with-action"><select id="ssid" name="ssid"></select><button type="button" class="ghost" id="scanNetworks">掃描</button></div><p class="hint">載入時自動掃描；網路變更後可手動重新整理。</p></div><div class="field"><label for="password">Wi-Fi 密碼</label><input id="password" name="password" type="password" autocomplete="off" placeholder="留空以保留原密碼"></div></section><section class="card"><h2><span>02</span>天氣與個人化</h2><p class="section-note">這些資料會影響電子紙上的日常資訊與圖片輪播。</p><div class="field"><label for="location">天氣地點</label><input id="location" name="location"></div><div class="field"><label for="birthday">生日 MMDD</label><input id="birthday" name="birthday" maxlength="4" pattern="[0-9]{4}"></div><div class="field"><label for="interval">圖片輪播間隔（分鐘）</label><input id="interval" name="image_interval_min" type="number" min="1" max="60"></div><div class="field"><label for="timezone">時區偏移</label><input id="timezone" name="timezone_offset" type="number" min="-12" max="14"></div></section><section class="card"><h2><span>03</span>感測與定時響聲</h2><div class="field"><label for="threshold">光感臨界值 0–65535</label><input id="threshold" name="light_threshold" type="number" min="0" max="65535"><p class="hint">目前 ADC：<strong id="adc">--</strong></p></div><div class="field check"><input id="chimeEnabled" name="chime_enabled" type="checkbox" value="true"><label for="chimeEnabled">啟用定時響聲</label></div><div class="field"><label for="chimeInterval">響聲間隔</label><select id="chimeInterval" name="chime_interval"><option value="hourly">每小時</option><option value="half_hourly">每半小時</option></select></div><div class="field"><label for="pitch">音高 Hz</label><input id="pitch" name="chime_pitch" type="number" min="100" max="5000"></div><div class="field"><label for="volume">音量 0–100</label><input id="volume" name="chime_volume" type="number" min="0" max="100"></div><button type="button" class="warn" id="testChime">播放測試響聲</button></section><section class="card"><h2><span>04</span>AP 與管理</h2><p class="section-note">管理 AP 與第三方服務的連線資訊。敏感欄位不會回填明文。</p><div class="field"><label for="apSsid">AP SSID</label><input id="apSsid" name="ap_mode_ssid"></div><div class="field"><label for="apPassword">AP 密碼</label><input id="apPassword" name="ap_mode_password" type="password" autocomplete="off" placeholder="留空以保留原密碼"></div><div class="field"><label>固定管理帳號</label><p class="hint">admin（不可變更）</p></div><div class="field"><label for="adminPassword">管理密碼</label><input id="adminPassword" name="lan_admin_password" type="password" autocomplete="new-password" placeholder="留空以保留原密碼"></div><div class="field"><label for="apiKey">OpenWeather API Key</label><input id="apiKey" name="api_key" type="password" autocomplete="off" placeholder="留空以保留"></div><div class="field check"><input id="clearApiKey" name="clear_weather_api_key" type="checkbox" value="true"><label for="clearApiKey">清除已儲存的 Weather API Key</label></div><div class="field"><label for="discord">Discord Webhook</label><input id="discord" name="discord_webhook_url" type="password" autocomplete="off" placeholder="留空以保留"></div><div class="field check"><input id="clearDiscord" name="clear_discord_webhook" type="checkbox" value="true"><label for="clearDiscord">清除已儲存的 Discord Webhook</label></div></section><section class="card wide danger-card"><h2><span>05</span>套用變更</h2><p class="section-note">儲存會讓裝置立即重啟；完全重置會刪除所有設定檔，且無法復原。</p><div class="actions"><button type="submit" id="save">儲存並重啟</button><button type="button" class="danger" id="factoryReset">完全重置</button></div></section></form></main><footer class="site-footer"><div class="footer-in"><div class="footer-repo"><span class="label">SOURCE</span><a href="https://github.com/Ning0612/pico-paper-clock">Ning0612/pico-paper-clock</a></div><div class="footer-meta">Vanilla HTML／CSS／JS · 無框架 · MIT License</div></div></footer><script>var q=new URLSearchParams(location.search),selected=q.get('profile')||'',form=document.getElementById('settings'),message=document.getElementById('message'),config=null,csrf='';function syncTheme(){var cur=document.documentElement.dataset.theme;document.querySelectorAll('.theme-toggle button').forEach(function(b){var on=b.dataset.themeChoice===cur;b.classList.toggle('active',on);b.setAttribute('aria-pressed',on?'true':'false')})}function setTheme(value){if(value!=='light'&&value!=='dark')value='light';document.documentElement.dataset.theme=value;try{localStorage.setItem('iot-ui-theme',value)}catch(e){}syncTheme()}document.querySelectorAll('.theme-toggle button').forEach(function(b){b.addEventListener('click',function(){setTheme(b.dataset.themeChoice)})});syncTheme();function note(text,error){message.textContent=text;message.className='message'+(error?' error':'');message.style.display='block'}function setValue(id,value){document.getElementById(id).value=value==null?'':value}function redirectLogin(){location.href='/login?next='+encodeURIComponent(location.pathname+location.search)}async function responseData(response){if(response.status===401){redirectLogin();throw new Error('登入已過期')}var data={};try{data=await response.json()}catch(e){}if(!response.ok){var error=new Error(data.message||('HTTP '+response.status));error.code=data.error||'';throw error}return data}async function request(url,options){return responseData(await fetch(url,options||{}))}async function refreshSession(){var session=await request('/api/v1/auth/session',{cache:'no-store'});csrf=session.csrf_token;document.getElementById('csrf').value=csrf;return session}async function postForm(url,values,retried){var data=Object.assign({},values,{csrf_token:csrf});try{return await request(url,{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded','X-CSRF-Token':csrf},body:new URLSearchParams(data).toString()})}catch(error){if(error.code==='csrf'&&!retried){await refreshSession();return postForm(url,values,true)}throw error}}async function load(){try{config=await request('/api/v1/config'+(selected?'?profile='+encodeURIComponent(selected):''),{cache:'no-store'});var p=config.profile,u=p.user||{},c=p.chime||{},g=config.global||{},profiles=document.getElementById('profiles');csrf=config.csrf_token||csrf;document.getElementById('csrf').value=csrf;profiles.innerHTML='';(config.profiles||[]).forEach(function(name){var option=document.createElement('option');option.value=name;option.textContent=name+(name===config.active_profile?' / active':'');option.selected=name===p.name;profiles.append(option)});setValue('profileName',p.name);setValue('originalName',p.name);setValue('location',p.weather_location);setValue('birthday',u.birthday);setValue('interval',u.image_interval_min);setValue('timezone',u.timezone_offset);setValue('threshold',u.light_threshold);document.getElementById('chimeEnabled').checked=!!c.enabled;setValue('chimeInterval',c.interval);setValue('pitch',c.pitch);setValue('volume',c.volume);setValue('apSsid',g.ap_mode_ssid);document.getElementById('apiKey').placeholder=g.weather_api_key_configured?'已設定；留空保留':'尚未設定';document.getElementById('discord').placeholder=g.discord_webhook_configured?'已設定；留空保留':'尚未設定';await loadNetworks(p.wifi&&p.wifi.ssid||'')}catch(error){note('載入設定失敗：'+error.message,true)}}async function loadNetworks(current){var select=document.getElementById('ssid'),button=document.getElementById('scanNetworks'),previous=select.value||current;button.disabled=true;button.textContent='掃描中…';try{var data=await request('/api/v1/networks',{cache:'no-store'}),names=(data.networks||[]).map(function(item){return typeof item==='string'?item:item.ssid}).filter(Boolean);if(previous&&!names.includes(previous))names.unshift(previous);select.innerHTML='';names.forEach(function(name){var option=document.createElement('option');option.value=name;option.textContent=name;option.selected=name===current||name===previous;select.append(option)});if(!names.length)note('掃描完成：目前沒有找到可用的 Wi-Fi。',false)}catch(error){note('Wi-Fi 掃描失敗：'+error.message,true)}finally{button.disabled=false;button.textContent='掃描'}}document.getElementById('scanNetworks').onclick=function(){loadNetworks(document.getElementById('ssid').value)};document.getElementById('profiles').onchange=function(e){location.href='/?profile='+encodeURIComponent(e.target.value)};document.getElementById('newProfile').onclick=async function(){var name=prompt('新設定檔名稱');if(!name||!name.trim())return;try{await postForm('/new_profile',{name:name.trim()});location.href='/'}catch(error){note('新增設定檔失敗：'+error.message,true)}};document.getElementById('deleteProfile').onclick=async function(){var name=document.getElementById('originalName').value;if(!confirm('確定刪除 '+name+'？此操作無法復原。'))return;try{await postForm('/delete_profile',{name:name});location.href='/'}catch(error){note('刪除設定檔失敗：'+error.message,true)}};document.getElementById('testChime').onclick=async function(){var button=this;button.disabled=true;try{await postForm('/test_chime',{pitch:document.getElementById('pitch').value,volume:document.getElementById('volume').value});note('已送出測試響聲。',false)}catch(error){note('測試響聲失敗：'+error.message,true)}finally{button.disabled=false}};document.getElementById('factoryReset').onclick=async function(){var answer=prompt('請輸入 RESET 確認完全重置');if(answer!=='RESET'||!confirm('最後確認：所有設定將被刪除。'))return;var button=this;button.disabled=true;try{await postForm('/factory_reset',{confirmation:'RESET'});note('完全重置已開始，裝置即將重新啟動。',false)}catch(error){note('完全重置失敗：'+error.message,true);button.disabled=false}};async function saveSettings(retried){var body=new URLSearchParams(new FormData(form));if(!document.getElementById('chimeEnabled').checked)body.delete('chime_enabled');body.set('csrf_token',csrf);try{await request('/api/v1/config',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded','X-CSRF-Token':csrf},body:body.toString()})}catch(error){if(error.code==='csrf'&&!retried){await refreshSession();return saveSettings(true)}throw error}}form.onsubmit=async function(event){event.preventDefault();var save=document.getElementById('save');save.disabled=true;save.textContent='儲存中…';try{await saveSettings(false);note('設定已儲存，裝置正在重啟…',false)}catch(error){note('儲存失敗：'+error.message,true);save.disabled=false;save.textContent='儲存並重啟'}};async function adc(){try{var data=await request('/adc',{cache:'no-store'});document.getElementById('adc').textContent=data.adc}catch(e){}}document.getElementById('logout').onclick=async function(){try{await postForm('/api/v1/auth/logout',{});location.href='/login'}catch(error){note('登出失敗：'+error.message,true)}};(async function(){var guarded=['newProfile','deleteProfile','testChime','save','factoryReset','scanNetworks'];guarded.forEach(function(id){document.getElementById(id).disabled=true});try{await refreshSession();await load();await adc();setInterval(adc,3000);guarded.forEach(function(id){document.getElementById(id).disabled=false})}catch(error){note('載入管理工作階段失敗：'+error.message,true)}})();</script></body></html>