Content-Type: text/html; charset=utf-8
Cache-Control: no-store

<!doctype html><html lang="zh-TW"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Pi Paper Clock / 設定完成</title><link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' fill='%230a100d'/%3E%3Crect x='2' y='2' width='28' height='28' fill='none' stroke='%23a8d2c4' stroke-width='2'/%3E%3Ctext x='16' y='21' font-family='Consolas,monospace' font-size='12' font-weight='700' fill='%23a8d2c4' text-anchor='middle'%3EPC%3C/text%3E%3C/svg%3E"><script>(function(){var k='iot-ui-theme',s=null;try{s=localStorage.getItem(k)}catch(e){}document.documentElement.dataset.theme=(s==='light'||s==='dark')?s:(matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light')})();</script><style>:root{color-scheme:light;--paper:#f1ede2;--surface:#fbf8ef;--ink:#17231f;--ink-soft:#263a34;--line:#b9b8aa;--muted:#68736c;--coral:#cf5a47;--teal:#0b716a;--teal-dark:#07534f;--mint:#a8d2c4;--grid-dot:rgba(23,35,31,.045);--dark-block-muted:#aab8ae;--on-dark:#fbf8ef;--on-light:#17231f;--nav-border:#71847a}:root[data-theme="dark"]{color-scheme:dark;--paper:#141b18;--surface:#1c2622;--ink:#eef1ea;--ink-soft:#0a100d;--line:#3a4a43;--muted:#93a69c;--coral:#e2705a;--teal:#1fae9c;--teal-dark:#167d70;--grid-dot:rgba(255,255,255,.035)}*{box-sizing:border-box}body{margin:0;min-height:100vh;background-color:var(--paper);background-image:linear-gradient(var(--grid-dot) 1px,transparent 1px),linear-gradient(90deg,var(--grid-dot) 1px,transparent 1px);background-size:20px 20px;color:var(--ink);font-family:Georgia,'Noto Serif TC',serif}.topbar{background:var(--ink-soft);border-bottom:5px solid var(--teal);color:var(--on-dark);padding:1rem}.topbar-in{max-width:1040px;margin:auto;display:flex;align-items:center;justify-content:space-between;gap:1rem}.brand{display:flex;align-items:center;gap:.7rem;color:inherit;text-decoration:none}.brand-mark{display:grid;place-items:center;width:2.25rem;height:2.25rem;border:2px solid var(--mint);color:var(--mint);font:700 1rem Consolas,monospace}.brand-copy{font:700 .82rem Consolas,monospace;letter-spacing:.08em}.brand-sub{display:block;margin-top:.22rem;color:var(--dark-block-muted);font:400 .68rem Consolas,monospace}.theme-toggle{display:flex;border:1px solid var(--nav-border);overflow:hidden}.theme-toggle button{border:0;border-radius:0;padding:.46rem .6rem;background:transparent;color:var(--on-dark);font:700 .68rem Consolas,monospace;cursor:pointer}.theme-toggle button+button{border-left:1px solid var(--nav-border)}.theme-toggle button.active{background:var(--mint);color:var(--on-light)}.theme-toggle button:focus-visible{outline:2px solid var(--mint);outline-offset:2px}.wrap{max-width:700px;margin:auto;padding:4rem 1rem}.card{position:relative;background:var(--surface);border:1px solid var(--ink);padding:2rem 1.5rem;text-align:center;box-shadow:5px 5px 0 var(--line)}.card:before{content:'';position:absolute;top:0;left:0;width:70px;height:5px;background:var(--teal)}.kicker{color:var(--teal);font:700 .72rem Consolas,monospace;letter-spacing:.14em;text-transform:uppercase}h1{font-size:clamp(2rem,7vw,3.5rem);line-height:.95;letter-spacing:-.06em;margin:.55rem 0 1rem}p{color:var(--muted);line-height:1.6;margin:.5rem auto;max-width:34rem}.countdown{margin:1.7rem 0 .8rem;color:var(--teal);font:700 4.4rem/.9 Consolas,monospace}.progress-bar{height:8px;max-width:320px;margin:1rem auto 1.3rem;background:var(--line);overflow:hidden}.progress-fill{height:100%;width:100%;background:var(--teal);animation:countdown 5s linear forwards}@keyframes countdown{to{width:0}}.redirect{font:700 .72rem Consolas,monospace;color:var(--muted)}.site-footer{background:var(--ink-soft);color:var(--dark-block-muted);margin-top:2rem;padding:1.2rem 1rem}.footer-in{max-width:1040px;margin:auto;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap}.footer-repo{display:flex;align-items:baseline;gap:.5rem;font:700 .74rem Consolas,monospace}.footer-repo .label{color:var(--mint);letter-spacing:.12em}.footer-repo a{color:var(--on-dark);text-decoration:none}.footer-repo a:hover{color:var(--mint)}.footer-meta{font:400 .7rem Consolas,monospace}@media(max-width:480px){.topbar-in,.footer-in{align-items:flex-start;flex-direction:column}}</style></head><body><header class="topbar"><div class="topbar-in"><a class="brand" href="/"><span class="brand-mark">PC</span><span class="brand-copy">PI PAPER CLOCK<span class="brand-sub">LOCAL DEVICE / CONTROL DECK</span></span></a><div class="theme-toggle" role="group" aria-label="配色主題切換"><button type="button" data-theme-choice="light" aria-pressed="false">LIGHT</button><button type="button" data-theme-choice="dark" aria-pressed="false">DARK</button></div></div></header><main class="wrap"><section class="card"><div class="kicker">CONFIGURATION / SAVED</div><h1>設定已儲存</h1><p>系統正在重新啟動，裝置會在啟動後自動連接 Wi-Fi。</p><div class="countdown" id="countdown">5</div><div class="progress-bar"><div class="progress-fill"></div></div><p class="redirect">請稍候，頁面會自動返回設定…</p></section></main><footer class="site-footer"><div class="footer-in"><div class="footer-repo"><span class="label">SOURCE</span><a href="https://github.com/Ning0612/pico-paper-clock">Ning0612/pico-paper-clock</a></div><div class="footer-meta">Vanilla HTML／CSS／JS · 無框架 · MIT License</div></div></footer><script>function syncTheme(){var cur=document.documentElement.dataset.theme;document.querySelectorAll('.theme-toggle button').forEach(function(b){var on=b.dataset.themeChoice===cur;b.classList.toggle('active',on);b.setAttribute('aria-pressed',on?'true':'false')})}function setTheme(value){if(value!=='light'&&value!=='dark')value='light';document.documentElement.dataset.theme=value;try{localStorage.setItem('iot-ui-theme',value)}catch(e){}syncTheme()}document.querySelectorAll('.theme-toggle button').forEach(function(b){b.onclick=function(){setTheme(b.dataset.themeChoice)}});syncTheme();var t=5,el=document.getElementById('countdown');setInterval(function(){t--;if(t>=0)el.textContent=t},1000);setTimeout(function(){location.href='/'},5000)</script></body></html>