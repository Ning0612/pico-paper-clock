<!doctype html><html lang="zh-TW"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Pi Paper Clock / 在席統計</title><link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' fill='%230a100d'/%3E%3Crect x='2' y='2' width='28' height='28' fill='none' stroke='%23a8d2c4' stroke-width='2'/%3E%3Ctext x='16' y='21' font-family='Consolas,monospace' font-size='12' font-weight='700' fill='%23a8d2c4' text-anchor='middle'%3EPC%3C/text%3E%3C/svg%3E"><script>(function(){var k='iot-ui-theme',s=null;try{s=localStorage.getItem(k)}catch(e){}document.documentElement.dataset.theme=(s==='light'||s==='dark')?s:(matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light')})();</script><style>:root{color-scheme:light;--paper:#f1ede2;--surface:#fbf8ef;--surface-2:#e7e3d6;--ink:#17231f;--ink-soft:#263a34;--line:#b9b8aa;--muted:#68736c;--teal:#0b716a;--teal-dark:#07534f;--coral:#cf5a47;--coral-dark:#a94436;--amber:#bd812d;--amber-dark:#98641d;--shadow:rgba(23,35,31,.15);--inset:#fffdf7;--input-border:#7e9188;--chart-grid:#d4d2c5;--unknown:#a9ada3;--placeholder:#9aa39b;--grid-dot:rgba(23,35,31,.045);--danger-surface:#fff6ed;--mint:#a8d2c4;--on-dark:#fbf8ef;--on-light:#17231f;--dark-block-muted:#aab8ae;--nav-border:#71847a;--on-ring:rgba(168,210,196,.18);--off-ring:rgba(207,90,71,.18)}:root[data-theme="dark"]{color-scheme:dark;--paper:#141b18;--surface:#1c2622;--surface-2:#24312c;--ink:#eef1ea;--ink-soft:#0a100d;--line:#3a4a43;--muted:#93a69c;--teal:#1fae9c;--teal-dark:#167d70;--coral:#e2705a;--coral-dark:#b8543f;--amber:#d99a3f;--amber-dark:#a97a2f;--shadow:rgba(0,0,0,.4);--inset:#101512;--input-border:#48584f;--chart-grid:#3a473f;--unknown:#6b756e;--placeholder:#66756c;--grid-dot:rgba(255,255,255,.035);--danger-surface:#241a16}*{box-sizing:border-box}body{margin:0;background-color:var(--paper);background-image:linear-gradient(var(--grid-dot) 1px,transparent 1px),linear-gradient(90deg,var(--grid-dot) 1px,transparent 1px);background-size:20px 20px;color:var(--ink);font-family:Georgia,'Noto Serif TC',serif;min-height:100vh}.topbar{background:var(--ink-soft);border-bottom:5px solid var(--coral);color:var(--on-dark);padding:1rem}.topbar-in{max-width:1040px;margin:auto;display:flex;align-items:center;justify-content:space-between;gap:1rem}.brand{display:flex;align-items:center;gap:.7rem;color:inherit;text-decoration:none}.brand-mark{display:grid;place-items:center;width:2.25rem;height:2.25rem;border:2px solid var(--mint);color:var(--mint);font:700 1rem Consolas,monospace}.brand-copy{font:700 .82rem Consolas,monospace;letter-spacing:.08em}.brand-sub{display:block;margin-top:.22rem;color:var(--dark-block-muted);font:400 .68rem Consolas,monospace;letter-spacing:.02em}.topbar-actions{display:flex;align-items:center;gap:.6rem;flex-wrap:wrap}.nav{display:flex;gap:.4rem;flex-wrap:wrap;justify-content:flex-end}.nav a{border:1px solid var(--nav-border);color:var(--on-dark);padding:.46rem .6rem;text-decoration:none;font:700 .72rem Consolas,monospace}.nav a:hover,.nav a.active{background:var(--mint);border-color:var(--mint);color:var(--on-light)}.theme-toggle{display:flex;border:1px solid var(--nav-border);overflow:hidden}.theme-toggle button{border:0;border-radius:0;padding:.46rem .6rem;background:transparent;color:var(--on-dark);font:700 .68rem Consolas,monospace;cursor:pointer}.theme-toggle button+button{border-left:1px solid var(--nav-border)}.theme-toggle button.active{background:var(--mint);color:var(--on-light)}.theme-toggle button:hover:not(.active){background:var(--on-ring)}.wrap{max-width:1040px;margin:auto;padding:1.4rem 1rem 3rem}.kicker{color:var(--teal);font:700 .72rem Consolas,monospace;letter-spacing:.14em;text-transform:uppercase}.intro{display:flex;align-items:flex-end;justify-content:space-between;gap:1.5rem;margin:.4rem 0 1.25rem}.intro h1{font-size:clamp(2rem,6vw,4rem);line-height:.92;letter-spacing:-.06em;margin:.45rem 0 0}.intro p{max-width:30rem;margin:0;color:var(--muted);line-height:1.55}.card{position:relative;background:var(--surface);border:1px solid var(--ink);padding:1.05rem;margin-bottom:1rem;box-shadow:5px 5px 0 var(--line)}.card:before{content:'';position:absolute;top:0;left:0;width:42px;height:4px;background:var(--teal)}.card h2{display:flex;align-items:baseline;gap:.55rem;margin:0 0 1rem;padding-bottom:.65rem;border-bottom:1px solid var(--line);font-size:1.05rem}.card h2 span{color:var(--coral);font:700 .7rem Consolas,monospace}.status-banner{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:1rem 1.1rem;margin-bottom:1rem;background:var(--ink-soft);color:var(--on-dark);box-shadow:5px 5px 0 var(--line)}.status-label{font:700 .7rem Consolas,monospace;letter-spacing:.12em;color:var(--mint)}.status-value{margin-top:.25rem;font-size:1.5rem}.status-value:before{content:'';display:inline-block;width:.7rem;height:.7rem;margin:0 .45rem .08rem 0;background:var(--mint);border-radius:50%;box-shadow:0 0 0 4px var(--on-ring)}.state-off .status-value:before{background:var(--coral);box-shadow:0 0 0 4px var(--off-ring)}.updated{color:var(--dark-block-muted);font:400 .7rem Consolas,monospace;text-align:right}.metric-grid,.summary-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.55rem}.metric{padding:.7rem;background:var(--inset);border:1px solid var(--line);min-height:78px}.metric label{display:block;color:var(--muted);font:700 .68rem Consolas,monospace;letter-spacing:.03em}.metric span{display:block;margin-top:.35rem;color:var(--teal);font:700 1.05rem Consolas,monospace;overflow-wrap:anywhere}.metric.state-off span{color:var(--coral)}.info{color:var(--muted);font-size:.82rem;line-height:1.5;margin:.85rem 0 0;padding:.65rem .75rem;background:var(--surface-2);border-left:3px solid var(--teal)}.legend-row{display:flex;gap:1rem;flex-wrap:wrap;color:var(--muted);font:400 .75rem Consolas,monospace;margin:.4rem 0}.key{display:inline-block;width:.72rem;height:.72rem;margin-right:.3rem;vertical-align:-1px}.key.on{background:var(--teal)}.key.off{background:var(--coral)}.key.unknown{background:var(--unknown)}canvas{display:block;width:100%;height:230px;margin-top:.5rem;background:var(--inset);border:1px solid var(--line)}#dailyChart{height:280px}.table-wrap{overflow-x:auto;border:1px solid var(--line)}table{width:100%;border-collapse:collapse;background:var(--inset);font:400 .78rem Consolas,monospace}th,td{padding:.62rem .65rem;border-bottom:1px solid var(--line);text-align:left;white-space:nowrap}th{background:var(--surface-2);color:var(--teal-dark);font-size:.68rem;letter-spacing:.04em}tbody tr:last-child td{border-bottom:0}.pill{display:inline-block;min-width:3.2rem;padding:.18rem .4rem;text-align:center;color:var(--on-dark);font:700 .68rem Consolas,monospace}.pill.on{background:var(--teal)}.pill.off{background:var(--coral)}.message{display:none;margin-bottom:1rem;padding:.8rem 1rem;border:1px solid var(--teal);border-left:5px solid var(--teal);background:var(--surface);font:700 .8rem Consolas,monospace}.message.error{border-color:var(--coral);color:var(--coral)}#tip{position:fixed;pointer-events:none;display:none;z-index:999;padding:.42rem .6rem;background:var(--ink-soft);color:var(--on-dark);font:700 .72rem Consolas,monospace;border:1px solid var(--mint)}.site-footer{background:var(--ink-soft);color:var(--dark-block-muted);margin-top:2rem;padding:1.2rem 1rem}.footer-in{max-width:1040px;margin:auto;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap}.footer-repo{display:flex;align-items:baseline;gap:.5rem;font:700 .74rem Consolas,monospace}.footer-repo .label{color:var(--mint);letter-spacing:.12em}.footer-repo a{color:var(--on-dark);text-decoration:none}.footer-meta{font:400 .7rem Consolas,monospace}@media(min-width:760px){.metric-grid{grid-template-columns:repeat(6,1fr)}}@media(max-width:720px){.topbar-in,.intro{align-items:flex-start;flex-direction:column}.nav{justify-content:flex-start}.topbar-actions{align-items:flex-start}.status-banner{align-items:flex-start;flex-direction:column}.updated{text-align:left}.wrap{padding-top:1rem}}@media(max-width:480px){.metric-grid,.summary-grid{grid-template-columns:repeat(2,1fr)}.metric:last-child{grid-column:1/-1}.footer-in{align-items:flex-start;flex-direction:column}}</style><style>.topbar .logout{border:1px solid var(--nav-border);border-radius:0;background:transparent;color:var(--on-dark);padding:.46rem .6rem;font:700 .68rem Consolas,monospace;cursor:pointer}.topbar .logout:hover{background:var(--mint);color:var(--on-light)}</style></head><body><header class="topbar"><div class="topbar-in"><a class="brand" href="/"><span class="brand-mark">PC</span><span class="brand-copy">PI PAPER CLOCK<span class="brand-sub">LOCAL DEVICE / CONTROL DECK</span></span></a><div class="topbar-actions"><nav class="nav" aria-label="主導覽"><a href="/">設定</a><a class="active" href="/dashboard">在席統計</a><a href="/images">圖片庫</a></nav><div class="theme-toggle" role="group" aria-label="配色主題切換"><button type="button" data-theme-choice="light" aria-pressed="false">LIGHT</button><button type="button" data-theme-choice="dark" aria-pressed="false">DARK</button></div><button type="button" class="logout ghost" id="logout">登出</button></div></div></header><main class="wrap"><div class="intro"><div><div class="kicker">02 / presence monitor</div><h1>在席統計</h1></div><p>以光感測器記錄桌前狀態。資料每 30 秒更新一次，時間軸顯示最近 24 小時的變化。</p></div><div class="message error" id="errorNote" aria-live="polite"></div><section class="status-banner" id="statusBanner" aria-live="polite"><div><div class="status-label">LIVE SENSOR STATUS</div><div class="status-value" id="state">讀取中…</div></div><div class="updated">最後切換<br><strong id="lastChange">--</strong></div></section><section class="card"><h2><span>01</span>目前狀態</h2><div class="metric-grid"><div class="metric" id="stateBox"><label>狀態</label><span id="stateMetric">--</span></div><div class="metric"><label>今日累計</label><span id="today">--</span></div><div class="metric"><label>目前區段</label><span id="segment">--</span></div><div class="metric"><label>今日切換</label><span id="transitions">--</span></div><div class="metric"><label>ADC / 門檻</label><span id="adc">--</span></div><div class="metric"><label>資料時間</label><span id="sampleTime">--</span></div></div><p class="info">當 ADC 小於或等於目前設定檔的光感臨界值時，會記錄為在桌前；其他時間則記錄為離開。</p></section><section class="card"><h2><span>02</span>最近 24 小時狀態切換</h2><div class="legend-row"><span><i class="key on"></i>在桌前</span><span><i class="key off"></i>離開</span><span><i class="key unknown"></i>資料不足</span></div><canvas id="timeline" width="900" height="230" aria-label="最近 24 小時在桌前與離開的時間軸"></canvas></section><section class="card"><h2><span>03</span>最近 30 天圖表</h2><div class="summary-grid"><div class="metric"><label>30 天平均</label><span id="avg30">--</span></div><div class="metric"><label>最高一天</label><span id="maxDay">--</span></div><div class="metric"><label>最近有記錄</label><span id="daysCount">--</span></div></div><canvas id="dailyChart" width="900" height="280" aria-label="最近 30 天每日在桌前時間圖表"></canvas></section><section class="card"><h2><span>04</span>每日統計</h2><div class="table-wrap"><table><thead><tr><th>日期</th><th>在桌前</th><th>比例</th><th>切換次數</th></tr></thead><tbody id="daily" aria-live="polite"></tbody></table></div></section><section class="card"><h2><span>05</span>最近切換</h2><div class="table-wrap"><table><thead><tr><th>時間</th><th>狀態</th><th>持續時間</th><th>ADC</th></tr></thead><tbody id="events" aria-live="polite"></tbody></table></div></section></main><footer class="site-footer"><div class="footer-in"><div class="footer-repo"><span class="label">SOURCE</span><a href="https://github.com/Ning0612/pico-paper-clock">Ning0612/pico-paper-clock</a></div><div class="footer-meta">Vanilla HTML／CSS／JS · 無框架 · MIT License</div></div></footer><div id="tip"></div><script>var dailyData=[],eventData=[],statusData=null,chartNow=0,dailyBars=[],csrf='';function syncTheme(){var cur=document.documentElement.dataset.theme;document.querySelectorAll('.theme-toggle button').forEach(function(b){var on=b.dataset.themeChoice===cur;b.classList.toggle('active',on);b.setAttribute('aria-pressed',on?'true':'false')})}function setTheme(value){if(value!=='light'&&value!=='dark')value='light';document.documentElement.dataset.theme=value;try{localStorage.setItem('iot-ui-theme',value)}catch(e){}syncTheme();if(statusData){drawDaily(dailyData);drawTimeline(eventData,chartNow,statusData)}}document.querySelectorAll('.theme-toggle button').forEach(function(b){b.onclick=function(){setTheme(b.dataset.themeChoice)}});syncTheme();function color(name){return getComputedStyle(document.documentElement).getPropertyValue(name).trim()}function fmt(s){s=Math.max(0,Number(s)||0);var h=Math.floor(s/3600),m=Math.floor(s%3600/60);return h+'h '+m+'m'}function pct(s){return Math.round(Math.max(0,Math.min(86400,Number(s)||0))*100/864)+'%'}function dateText(d){return d&&d.length>=8?d.slice(0,4)+'-'+d.slice(4,6)+'-'+d.slice(6,8):'--'}function timeText(t){return t&&t.length>=6?t.slice(0,2)+':'+t.slice(2,4)+':'+t.slice(4,6):'--'}function stateText(s){return s?'在桌前':'離開'}function sortEvents(ev){return (ev||[]).filter(function(x){return x&&x.e>0}).sort(function(a,b){return a.e-b.e})}function rowState(s){return '<span class="pill '+(s?'on':'off')+'">'+stateText(s)+'</span>'}dateText=function(d){return /^\d{8}$/.test(String(d||''))?d.slice(0,4)+'-'+d.slice(4,6)+'-'+d.slice(6,8):'--'};timeText=function(t){return /^\d{6}$/.test(String(t||''))?t.slice(0,2)+':'+t.slice(2,4)+':'+t.slice(4,6):'--'};function redirectLogin(){location.href='/login?next='+encodeURIComponent(location.pathname+location.search)}async function json(url,options,retried){var response=await fetch(url,options||{cache:'no-store'});if(response.status===401){redirectLogin();throw new Error('登入已過期')}var data={};try{data=await response.json()}catch(e){}if(!response.ok){var error=new Error(data.message||('HTTP '+response.status));error.code=data.error||'';if(error.code==='csrf'&&!retried&&options&&options.method){var session=await json('/api/v1/auth/session',{cache:'no-store'});var retryOptions=Object.assign({},options),headers=Object.assign({},options.headers||{});headers['X-CSRF-Token']=session.csrf_token;retryOptions.headers=headers;return json(url,retryOptions,true)}throw error}return data}function showError(text){var box=document.getElementById('errorNote');box.textContent=text;box.style.display='block'}async function load(){try{var values=await Promise.all([json('/presence/status'),json('/presence/events'),json('/presence/daily')]),st=values[0],ev=sortEvents(values[1]),da=values[2],now=Number(st.now_epoch)||Math.floor(Date.now()/1000),label=stateText(st.state);statusData=st;eventData=ev;dailyData=da;chartNow=now;document.getElementById('errorNote').style.display='none';document.getElementById('state').textContent=label;document.getElementById('stateMetric').textContent=label;document.getElementById('stateBox').className='metric '+(st.state?'state-on':'state-off');document.getElementById('statusBanner').className='status-banner '+(st.state?'state-on':'state-off');document.getElementById('today').textContent=fmt(st.today_seconds);document.getElementById('segment').textContent=fmt(st.segment_seconds||st.session_seconds);document.getElementById('transitions').textContent=st.transitions||0;document.getElementById('adc').textContent=st.adc+' / '+st.threshold;document.getElementById('lastChange').textContent=st.last_change_date?dateText(st.last_change_date)+' '+timeText(st.last_change_time):'--';document.getElementById('sampleTime').textContent=now?new Date(now*1000).toLocaleTimeString('zh-TW',{hour:'2-digit',minute:'2-digit'}):'--';renderDaily(da);renderEvents(ev,now);drawDaily(da);drawTimeline(ev,now,st)}catch(error){showError('暫時無法連線：'+error.message)}}function renderDaily(data){var rows=(data||[]).slice(-30),sum=rows.reduce(function(a,x){return a+(Number(x.sec)||0)},0),max=rows.reduce(function(m,x){return (Number(x.sec)||0)>(Number(m.sec)||0)?x:m},{sec:0,d:''});document.getElementById('avg30').textContent=rows.length?fmt(sum/rows.length):'--';document.getElementById('maxDay').textContent=max.d?dateText(max.d)+' '+fmt(max.sec):'--';document.getElementById('daysCount').textContent=rows.length;document.getElementById('daily').innerHTML=rows.slice().reverse().map(function(x){return '<tr><td>'+dateText(x.d)+'</td><td>'+fmt(x.sec)+'</td><td>'+pct(x.sec)+'</td><td>'+x.n+'</td></tr>'}).join('')}function renderEvents(ev,now){var rows=ev.slice(-40).reverse().map(function(x,i,a){var newer=a[i-1],end=newer?newer.e:now;return '<tr><td>'+dateText(x.d)+' '+timeText(x.t)+'</td><td>'+rowState(x.s)+'</td><td>'+fmt(end-x.e)+'</td><td>'+x.a+'</td></tr>'});document.getElementById('events').innerHTML=rows.join('')}function drawDaily(data){var rows=(data||[]).slice(-30),c=document.getElementById('dailyChart'),g=c.getContext('2d'),w=c.width,h=c.height,p=44,chH=h-64,ink=color('--ink'),inset=color('--inset'),grid=color('--chart-grid'),muted=color('--muted'),teal=color('--teal');g.clearRect(0,0,w,h);g.fillStyle=inset;g.fillRect(0,0,w,h);g.strokeStyle=grid;g.fillStyle=muted;g.font='12px Consolas,monospace';for(var i=0;i<=4;i++){var y=20+chH*i/4;g.beginPath();g.moveTo(p,y);g.lineTo(w-14,y);g.stroke();g.fillText(24-6*i+'h',8,y+4)}var bw=(w-p-18)/Math.max(1,rows.length);dailyBars=[];rows.forEach(function(r,index){var sec=Number(r.sec)||0,bh=chH*Math.min(1,sec/86400),bx=p+4+index*bw,bw2=Math.max(3,bw-5);if(sec>0){g.fillStyle=teal;g.fillRect(bx,h-44-bh,bw2,bh);dailyBars.push({x:bx,y:h-44-bh,w:bw2,h:bh,sec:sec,d:r.d});if(r.d&&r.d.length>=8){g.fillStyle=muted;g.font='10px Consolas,monospace';g.textAlign='center';g.fillText(r.d.slice(4,6)+'/'+r.d.slice(6,8),bx+bw2/2,h-18);g.font='12px Consolas,monospace';g.textAlign='left'}}});g.fillStyle=ink;g.fillText('最近 30 天每日在桌前時間',p,16)}function drawBand(g,x0,x1,y,h,colorValue){g.fillStyle=colorValue;g.fillRect(x0,y,Math.max(1,x1-x0),h);g.strokeStyle=color('--inset');g.strokeRect(x0,y,Math.max(1,x1-x0),h)}function drawTimeline(ev,now,st){var c=document.getElementById('timeline'),g=c.getContext('2d'),w=c.width,h=c.height,start=now-86400,x0=70,x1=w-16,top=42,bh=48,inset=color('--inset'),grid=color('--chart-grid'),muted=color('--muted'),ink=color('--ink'),teal=color('--teal'),coral=color('--coral'),unknown=color('--unknown');g.clearRect(0,0,w,h);g.fillStyle=inset;g.fillRect(0,0,w,h);g.font='12px Consolas,monospace';g.fillStyle=muted;for(var i=0;i<=6;i++){var x=x0+(x1-x0)*i/6;g.strokeStyle=grid;g.beginPath();g.moveTo(x,28);g.lineTo(x,h-34);g.stroke();var td=new Date((now-(24-4*i)*3600)*1e3),th=String(td.getHours()).padStart(2,'0'),tm=String(td.getMinutes()).padStart(2,'0');g.fillText(th+':'+tm,x-15,h-14)}g.fillStyle=muted;g.fillText('在桌前',12,top+18);g.fillText('離開',24,top+bh+34);drawBand(g,x0,x1,top,bh,unknown);var intervals=[];for(var j=0;j<ev.length;j++){var a=ev[j],b=ev[j+1],from=Math.max(start,a.e),to=Math.min(now,b?b.e:now);if(to>start&&from<now)intervals.push({f:from,t:to,s:a.s})}if(intervals.length&&intervals[0].f>start){var first=intervals[0];intervals.unshift({f:start,t:first.f,s:first.s?0:1,u:1})}intervals.forEach(function(r){var xx=x0+(x1-x0)*(r.f-start)/86400,ww=(x1-x0)*(r.t-r.f)/86400,y=r.s?top:top+bh+16;drawBand(g,xx,xx+ww,y,bh,r.u?unknown:(r.s?teal:coral))});g.fillStyle=ink;g.fillText('最近 24 小時',x0,18)}function initTooltip(){var c=document.getElementById('dailyChart'),tip=document.getElementById('tip');c.addEventListener('mousemove',function(event){var rect=c.getBoundingClientRect();if(!rect.width||!rect.height)return;var sx=c.width/rect.width,sy=c.height/rect.height,mx=(event.clientX-rect.left)*sx,my=(event.clientY-rect.top)*sy,found=false;for(var i=0;i<dailyBars.length;i++){var b=dailyBars[i];if(mx>=b.x&&mx<=b.x+b.w&&my>=b.y&&my<=b.y+b.h){tip.style.display='block';tip.style.left=event.clientX+12+'px';tip.style.top=event.clientY-36+'px';tip.textContent=(b.d?dateText(b.d)+' ':'')+fmt(b.sec);found=true;break}}if(!found)tip.style.display='none'});c.addEventListener('mouseleave',function(){tip.style.display='none'})}document.getElementById('logout').onclick=async function(){try{var session=await json('/api/v1/auth/session',{cache:'no-store'});await json('/api/v1/auth/logout',{method:'POST',headers:{'X-CSRF-Token':session.csrf_token}});location.href='/login'}catch(error){showError('登出失敗：'+error.message)}};(async function(){try{await json('/api/v1/auth/session');initTooltip();await load();setInterval(load,30000)}catch(error){showError('載入管理工作階段失敗：'+error.message)}})();</script></body></html>